public void rejectOrder(String orderId, String partnerId) {

    Order order = findOrder(orderId);

    if (!partnerId.equals(order.getDeliveryPartnerId())) {
        throw new IllegalStateException(
                "You are not assigned to this order."
        );
    }

    // Make rejecting partner available again
    DeliveryPartner rejectingPartner =
            partnerRepository.findById(partnerId)
                    .orElseThrow(() ->
                            new IllegalArgumentException("Partner not found"));

    rejectingPartner.setAvailable(true);

    // Remove current assignment
    order.assignDeliveryPartner(null);

    // Try reassigning
    List<DeliveryPartner> partners =
            partnerRepository.findAll();

    DeliveryPartner newPartner =
            deliveryStrategy.assign(order, partners);

    order.assignDeliveryPartner(newPartner.getId());
    newPartner.setAvailable(false);

    orderRepository.save(order);
}



public void assignDeliveryPartner(String partnerId) {
    this.deliveryPartnerId = partnerId;
    this.status = OrderStatus.ASSIGNED;
}

private void rejectOrder() {

    List<Order> orders = orderService
            .getOrdersByPartner(loggedInPartner.getId())
            .stream()
            .filter(o -> o.getStatus() == OrderStatus.ASSIGNED)
            .toList();

    if (orders.isEmpty()) {
        System.out.println("No orders to reject.");
        return;
    }

    Order selected = selectOrder(orders);

    if (selected == null) return;

    orderService.rejectOrder(
            selected.getId(),
            loggedInPartner.getId()
    );

    System.out.println("Order reassigned to next available partner.");
}